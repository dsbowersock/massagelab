# Runtime Prisma Client connection. Use Neon's pooled connection string.
DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Prisma CLI and seed connection. Prefer Neon's direct connection string here.
DIRECT_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Optional fallback when Vercel's Neon integration injects this instead of DIRECT_URL.
DATABASE_URL_UNPOOLED=

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
# Also accepted: NEXTAUTH_SECRET / NEXTAUTH_URL

# Google OAuth. In Google Cloud Console, add these authorized redirect URIs:
# http://localhost:3000/api/auth/callback/google
# https://massagelab.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Also accepted: AUTH_GOOGLE_CLIENT_ID / AUTH_GOOGLE_CLIENT_SECRET
# Also accepted: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET

# Resend SMTP example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=replace-with-resend-api-key
# SMTP_FROM="MassageLab <no-reply@massagelab.app>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MassageLab <no-reply@example.com>"
TOTP_ENCRYPTION_KEY="replace-with-a-long-random-key"

# Comma-separated emails that should receive the ADMIN role after sign-in.
ADMIN_EMAILS=

# Hosted clinical sync is intentionally disabled by default.
# Do not enable these in production until compliant hosting, BAAs, risk review,
# audit controls, and PHI-safe operations are complete.
MASSAGELAB_ENABLE_HOSTED_PHI_SYNC=false
MASSAGELAB_HIPAA_BAA_CONFIRMED=false
MASSAGELAB_HIPAA_RISK_REVIEW_CONFIRMED=false

# Sentry observability. The first integration captures errors and traces only.
# Do not enable Session Replay, User Feedback, or Logs until MassageLab has a
# route-by-route privacy review and Sentry project scrubbing rules in place.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
MASSAGELAB_ENABLE_SENTRY_TEST_ROUTE=false

# Stripe Billing. Free access is internal and should not be represented by a Stripe product.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_DONATION_URL=
STRIPE_SUPPORTER_1_MONTHLY_PRICE_ID=
STRIPE_SUPPORTER_1_YEARLY_PRICE_ID=
STRIPE_SUPPORTER_2_MONTHLY_PRICE_ID=
STRIPE_SUPPORTER_2_YEARLY_PRICE_ID=
STRIPE_SUPPORTER_5_MONTHLY_PRICE_ID=
STRIPE_SUPPORTER_5_YEARLY_PRICE_ID=

# Keep these legacy runtime mappings until subscriber inventory proves none remain and webhook reconciliation is final.
# They normalize historical webhook/database records only and never satisfy the
# six-Price public catalog readiness contract above.
STRIPE_SUPPORTER_MONTHLY_PRICE_ID=
STRIPE_SUPPORTER_YEARLY_PRICE_ID=
STRIPE_THERAPIST_MONTHLY_PRICE_ID=
STRIPE_THERAPIST_YEARLY_PRICE_ID=
STRIPE_PRACTICE_MONTHLY_PRICE_ID=
STRIPE_PRACTICE_YEARLY_PRICE_ID=

# New recurring Supporter Checkout stays fail-closed until every gate is
# explicitly confirmed. Leave these false/blank until final professional tax
# classification and the applicable Stripe Tax origin/registrations are ready.
STRIPE_SUPPORTER_AUTOMATIC_TAX_ENABLED=false
STRIPE_SUPPORTER_TAX_PRODUCT_CODE=
STRIPE_SUPPORTER_TAX_PROVIDER_READY=false
STRIPE_SUPPORTER_TAX_REGISTRATIONS_READY=false
STRIPE_SUPPORTER_TAX_CLASSIFICATION_CONFIRMED=false

# One-time Supporter catalog migration inputs. Keep these out of normal runtime
# configuration after the migration is verified. Use exact Stripe object IDs;
# set the Supporter Product value to CREATE_NEW only after verifying no reusable
# target Product exists. Use "none" for the allowed subscription only when a
# complete Stripe inventory proves no active, trialing, past-due, unpaid, paused,
# incomplete, or canceling subscription exists.
MASSAGELAB_STRIPE_MIGRATION_MODE=
MASSAGELAB_STRIPE_MIGRATION_ALLOWED_SUBSCRIPTION_ID=
MASSAGELAB_STRIPE_MIGRATION_SUPPORTER_PRODUCT_ID=
MASSAGELAB_STRIPE_MIGRATION_LEGACY_SUPPORTER_MONTHLY_PRICE_ID=
MASSAGELAB_STRIPE_MIGRATION_LEGACY_SUPPORTER_YEARLY_PRICE_ID=
MASSAGELAB_STRIPE_MIGRATION_THERAPIST_PRODUCT_ID=
MASSAGELAB_STRIPE_MIGRATION_THERAPIST_MONTHLY_PRICE_ID=
MASSAGELAB_STRIPE_MIGRATION_THERAPIST_YEARLY_PRICE_ID=
MASSAGELAB_STRIPE_MIGRATION_PRACTICE_PRODUCT_ID=
MASSAGELAB_STRIPE_MIGRATION_PRACTICE_MONTHLY_PRICE_ID=
MASSAGELAB_STRIPE_MIGRATION_PRACTICE_YEARLY_PRICE_ID=
MASSAGELAB_STRIPE_MIGRATION_STUDENT_COUPON_ID=
MASSAGELAB_STRIPE_MIGRATION_EARLY_ACCESS_COUPON_ID=
MASSAGELAB_STRIPE_MIGRATION_PORTAL_CONFIGURATION_ID=

# Anatomy media storage. Files live in Cloudflare R2; the database stores
# license/provenance metadata plus storage keys and public URLs when configured.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
MASSAGELAB_R2_BUCKET=massagelab-anatomy-media
MASSAGELAB_R2_ENDPOINT=
MASSAGELAB_R2_PUBLIC_BASE_URL=
MASSAGELAB_R2_CACHE_CONTROL="public, max-age=31536000, immutable"

# Public non-PHI media storage. Atmosphere audio samples should use the public
# media bucket, not the anatomy or private media buckets.
MASSAGELAB_PUBLIC_MEDIA_BUCKET=massagelab-public-media
MASSAGELAB_PUBLIC_MEDIA_R2_ENDPOINT=
MASSAGELAB_PUBLIC_MEDIA_PUBLIC_BASE_URL=https://media.massagelab.app
MASSAGELAB_PUBLIC_MEDIA_OBJECT_PREFIX=atmosphere/observable-streams-vsco-adaptation
MASSAGELAB_PUBLIC_MEDIA_CACHE_CONTROL="public, max-age=31536000, immutable"
MASSAGELAB_PUBLIC_MEDIA_METADATA_CACHE_CONTROL="public, max-age=300, must-revalidate"
