# Runtime Prisma Client connection. Use Neon's pooled connection string.
DATABASE_URL="postgresql://user:password@ep-example-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Prisma CLI and seed connection. Prefer Neon's direct connection string here.
DIRECT_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Optional fallback when Vercel's Neon integration injects this instead of DIRECT_URL.
DATABASE_URL_UNPOOLED=

AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
# Also accepted: NEXTAUTH_SECRET / NEXTAUTH_URL

# Google OAuth. In Google Cloud Console, add these authorized redirect URIs:
# http://localhost:3000/api/auth/callback/google
# https://massagelab.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Also accepted: AUTH_GOOGLE_CLIENT_ID / AUTH_GOOGLE_CLIENT_SECRET
# Also accepted: GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET

# Resend SMTP example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=replace-with-resend-api-key
# SMTP_FROM="MassageLab <no-reply@massagelab.app>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MassageLab <no-reply@example.com>"
TOTP_ENCRYPTION_KEY="replace-with-a-long-random-key"

# Comma-separated emails that should receive the ADMIN role after sign-in.
ADMIN_EMAILS=
