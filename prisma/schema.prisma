generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  STUDENT
  LICENSED_THERAPIST
  CLIENT
  EDITOR
  ADMIN
}

enum AuthAttemptPurpose {
  LOGIN
  REGISTER
  PASSWORD_RESET
  TWO_FACTOR
}

enum AnatomyKind {
  SYSTEM
  ORGAN
  TISSUE
  BONE
  MUSCLE
  JOINT
  NERVE
  VESSEL
  LIGAMENT
  TENDON
  CELL
  OTHER
}

enum AnatomyDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AnatomyStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProgressStatus {
  STARTED
  PRACTICING
  MASTERED
  SKIPPED
}

enum CorrectionFlagStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  EXPIRED
  REJECTED
  REVOKED
}

enum CredentialKind {
  MASSAGE_LICENSE
  STUDENT_ENROLLMENT
  INTERSTATE_MASSAGE_COMPACT
  MANUAL_REVIEW
}

enum VerificationSourceType {
  SELF_ATTESTATION
  STATE_LICENSE_LOOKUP
  DOCUMENT_REVIEW
  MANUAL_REVIEW
  COMPACT_REGISTRY
}

enum JurisdictionSupportStatus {
  ADAPTER_AVAILABLE
  PUBLIC_LOOKUP_AVAILABLE
  MANUAL_REVIEW_REQUIRED
  PLANNED
  UNSUPPORTED
}

enum TherapistClientStatus {
  INVITED
  ACTIVE
  PAUSED
  REVOKED
}

enum ClinicalArtifactKind {
  SOAP_NOTE
  INTAKE_FORM
  PAIN_JOURNAL
  SENSATION_JOURNAL
  INCIDENT_JOURNAL
  ROM_MEASUREMENT
  MOVEMENT_SESSION
}

enum ClinicalArtifactStatus {
  LOCAL_ONLY
  DRAFT
  FINALIZED
  RELEASE_REQUESTED
  RELEASED
  ARCHIVED
}

enum PracticeRole {
  OWNER
  THERAPIST
  STAFF
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  CLIENT_REQUEST
  THERAPIST_CREATED
}

enum CalendarEventKind {
  APPOINTMENT
  PERSONAL
  CLASS
  REMINDER
}

enum CalendarEventStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  ACTIVE
}

enum CalendarEventVisibility {
  PRIVATE
  PRACTICE
  CLIENT_VISIBLE
}

enum CalendarClassEnrollmentStatus {
  OPEN
  CLOSED
  WAITLIST
  CANCELLED
}

enum CalendarNotificationChannel {
  INTERNAL
}

enum CalendarNotificationStatus {
  PENDING
  CANCELLED
  DELIVERED
}

enum CalendarAvailabilityOverrideKind {
  OPEN
  CLOSED
  BLACKOUT
  HOLIDAY
}

enum BookingApprovalMode {
  MANUAL
  AUTO_CONFIRM
}

enum BookingStaffVisibility {
  PUBLIC_LABELS
  HIDE_STAFF
}

enum BookingCapacityPeriod {
  DAILY
  WEEKLY
}

enum ServiceBookingRole {
  PRIMARY
  ADD_ON
}

enum BookingGroupStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BookingWaitlistStatus {
  OPEN
  BOOKED
  CANCELLED
}

enum MembershipLevel {
  SUPPORTER
  THERAPIST
  PRACTICE
}

enum StudentAccessStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model User {
  id                    String                   @id @default(cuid())
  name                  String?
  email                 String?                  @unique
  emailVerified         DateTime?
  image                 String?
  accounts              Account[]
  sessions              Session[]
  roles                 UserRole[]
  grantedRoles          UserRole[]                @relation("GrantedUserRoles")
  profile               UserProfile?
  preference            UserPreference?
  passwordCredential    PasswordCredential?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  twoFactorSecret       TwoFactorSecret?
  backupCodes           BackupCode[]
  learningProgress      LearningProgress[]
  achievements          Achievement[]
  noteTemplates         NoteTemplate[]
  formTemplates         FormTemplate[]
  documentationPreference DocumentationPreference?
  credentialVerifications CredentialVerification[] @relation("CredentialVerificationUser")
  verifiedCredentialClaims VerifiedCredentialClaim[]
  reviewedCredentialVerifications CredentialVerification[] @relation("CredentialVerificationReviewer")
  therapistRelationships TherapistClientRelationship[] @relation("TherapistClientRelationships")
  clientRelationships   TherapistClientRelationship[] @relation("ClientClientRelationships")
  authoredClinicalArtifactManifests ClinicalArtifactManifest[] @relation("ClinicalArtifactAuthor")
  subjectClinicalArtifactManifests ClinicalArtifactManifest[] @relation("ClinicalArtifactSubject")
  therapistClinicalArtifactManifests ClinicalArtifactManifest[] @relation("ClinicalArtifactTherapist")
  clinicalAuditLogs     ClinicalAccessAuditLog[]  @relation("ClinicalAuditActor")
  clinicalAuditTargets  ClinicalAccessAuditLog[]  @relation("ClinicalAuditTarget")
  correctionFlags       AnatomyCorrectionFlag[]  @relation("CorrectionFlagCreator")
  reviewedFlags         AnatomyCorrectionFlag[]  @relation("CorrectionFlagReviewer")
  createdTerms          AnatomyTerm[]            @relation("AnatomyTermCreator")
  updatedTerms          AnatomyTerm[]            @relation("AnatomyTermUpdater")
  auditLogs             AnatomyAuditLog[]         @relation("AnatomyAuditActor")
  createdPractices      Practice[]               @relation("PracticeCreator")
  practiceMemberships   PracticeMembership[]
  practiceClients       PracticeClient[]
  availabilityRules     TherapistAvailabilityRule[] @relation("AvailabilityTherapist")
  availabilitySchedules CalendarAvailabilitySchedule[] @relation("AvailabilityScheduleTherapist")
  availabilityOverrides CalendarAvailabilityOverride[] @relation("AvailabilityOverrideTherapist")
  providerBookingPolicies ProviderBookingPolicy[] @relation("ProviderBookingPolicyProvider")
  providerBookingCapacityRules ProviderBookingCapacityRule[] @relation("ProviderBookingCapacityRuleProvider")
  ownedCalendarEvents   CalendarEvent[]          @relation("CalendarEventOwner")
  createdCalendarEvents CalendarEvent[]          @relation("CalendarEventCreator")
  calendarBlocks        CalendarBlock[]          @relation("CalendarBlockTherapist")
  appointmentsAsTherapist Appointment[]           @relation("AppointmentTherapist")
  createdAppointments   Appointment[]            @relation("AppointmentCreator")
  createdBookingGroups  BookingGroup[]           @relation("BookingGroupCreator")
  createdBookingWaitlistEntries BookingWaitlistEntry[] @relation("BookingWaitlistCreator")
  instructedCalendarClasses CalendarClass[]       @relation("CalendarClassInstructor")
  calendarAuditLogs     CalendarAuditLog[]       @relation("CalendarAuditActor")
  createdNotificationIntents CalendarNotificationIntent[] @relation("CalendarNotificationActor")
  receivedNotificationIntents CalendarNotificationIntent[] @relation("CalendarNotificationRecipient")
  stripeCustomer        StripeCustomer?
  membershipSubscriptions MembershipSubscription[]
  studentAccess         StudentAccess?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  email       String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorSecret {
  id              String    @id @default(cuid())
  userId          String    @unique
  encryptedSecret String
  enabledAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRole {
  id          String             @id @default(cuid())
  userId      String
  role        Role               @default(USER)
  status      VerificationStatus @default(VERIFIED)
  source      String             @default("system")
  metadata    Json               @default("{}")
  verifiedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  grantedById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?              @relation("GrantedUserRoles", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([role, status])
  @@index([userId, status])
}

model UserProfile {
  userId              String   @id
  displayName         String?
  therapistName       String?
  therapistLocation   String?
  licenseNumber       String?
  licenseOrganization String?
  npiNumber           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CredentialVerification {
  id                  String                 @id @default(cuid())
  userId              String
  kind                CredentialKind
  role                Role?
  status              VerificationStatus     @default(PENDING)
  jurisdictionCode    String?
  credentialNumber    String?
  issuingAuthority    String?
  displayLabel        String?
  sourceType          VerificationSourceType @default(SELF_ATTESTATION)
  sourceUrl           String?
  evidenceDescription String?
  verificationPayload Json                   @default("{}")
  checkedAt           DateTime?
  verifiedAt          DateTime?
  expiresAt           DateTime?
  rejectedAt          DateTime?
  revokedAt           DateTime?
  reviewedById        String?
  reviewNote          String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation("CredentialVerificationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer            User?                  @relation("CredentialVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, kind, jurisdictionCode, credentialNumber])
  @@index([userId, kind, status])
  @@index([jurisdictionCode, status])
  @@index([role, status])
}

model VerifiedCredentialClaim {
  id                         String         @id @default(cuid())
  userId                     String
  kind                       CredentialKind
  jurisdictionCode           String
  normalizedCredentialNumber String
  credentialVerificationId   String?
  source                     String
  claimedAt                  DateTime       @default(now())
  expiresAt                  DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  user                       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kind, jurisdictionCode, normalizedCredentialNumber])
  @@index([userId, kind])
  @@index([credentialVerificationId])
}

model JurisdictionVerifier {
  id              String                    @id @default(cuid())
  jurisdictionCode String                   @unique
  jurisdictionName String
  countryCode     String                    @default("US")
  massageBoardName String?
  lookupUrl       String?
  supportStatus   JurisdictionSupportStatus @default(MANUAL_REVIEW_REQUIRED)
  compactEligible Boolean                   @default(false)
  compactStatus   String?
  notes           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([countryCode, supportStatus])
}

model TherapistClientRelationship {
  id            String                 @id @default(cuid())
  therapistUserId String
  clientUserId  String?
  clientEmail   String?
  status        TherapistClientStatus  @default(INVITED)
  invitedAt     DateTime               @default(now())
  acceptedAt    DateTime?
  pausedAt      DateTime?
  revokedAt     DateTime?
  metadata      Json                   @default("{}")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  therapist     User                   @relation("TherapistClientRelationships", fields: [therapistUserId], references: [id], onDelete: Cascade)
  client        User?                  @relation("ClientClientRelationships", fields: [clientUserId], references: [id], onDelete: SetNull)
  clinicalArtifactManifests ClinicalArtifactManifest[]

  @@unique([therapistUserId, clientUserId])
  @@index([therapistUserId, status])
  @@index([clientUserId, status])
  @@index([clientEmail])
}

model ClinicalArtifactManifest {
  id             String                 @id @default(cuid())
  kind           ClinicalArtifactKind
  status         ClinicalArtifactStatus @default(LOCAL_ONLY)
  schemaVersion  Int                    @default(1)
  localDocumentId String
  authorUserId   String?
  subjectUserId  String?
  therapistUserId String?
  relationshipId String?
  finalizedAt    DateTime?
  releaseRequestedAt DateTime?
  releasedAt     DateTime?
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  author         User?                  @relation("ClinicalArtifactAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  subject        User?                  @relation("ClinicalArtifactSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  therapist      User?                  @relation("ClinicalArtifactTherapist", fields: [therapistUserId], references: [id], onDelete: SetNull)
  relationship   TherapistClientRelationship? @relation(fields: [relationshipId], references: [id], onDelete: SetNull)
  auditLogs      ClinicalAccessAuditLog[]

  @@unique([localDocumentId])
  @@index([authorUserId, kind])
  @@index([subjectUserId, kind])
  @@index([therapistUserId, status])
  @@index([relationshipId, status])
}

model ClinicalAccessAuditLog {
  id                 String   @id @default(cuid())
  actorUserId        String?
  targetUserId       String?
  clinicalArtifactId String?
  action             String
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  actor              User?    @relation("ClinicalAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target             User?    @relation("ClinicalAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  clinicalArtifact   ClinicalArtifactManifest? @relation(fields: [clinicalArtifactId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([clinicalArtifactId, createdAt])
  @@index([action, createdAt])
}

model UserPreference {
  userId            String   @id
  version           Int      @default(1)
  appSettings       Json     @default("{}")
  chimerSettings    Json     @default("{}")
  anatomimeSettings Json     @default("{}")
  notePreferences   Json     @default("{}")
  calendarPreferences Json   @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentationPreference {
  userId      String   @id
  version     Int      @default(1)
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NoteTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  kind      String
  content   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

model FormTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  kind      String
  schema    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

model LearningProgress {
  id            String         @id @default(cuid())
  userId        String
  anatomyTermId String?
  tool          String
  status        ProgressStatus @default(STARTED)
  score         Int?
  metadata      Json           @default("{}")
  lastSeenAt    DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anatomyTerm   AnatomyTerm?   @relation(fields: [anatomyTermId], references: [id], onDelete: Cascade)

  @@unique([userId, anatomyTermId, tool])
  @@index([userId, tool])
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  key       String
  tool      String
  metadata  Json     @default("{}")
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, tool])
}

model AnatomyTerm {
  id             String                 @id @default(cuid())
  slug           String                 @unique
  kind           AnatomyKind
  preferredName  String
  summary        String?
  regions        String[]               @default([])
  bodySystems    String[]               @default([])
  difficulty     AnatomyDifficulty      @default(MEDIUM)
  status         AnatomyStatus          @default(DRAFT)
  createdById    String?
  updatedById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  aliases        AnatomyAlias[]
  sourceRelationships AnatomyRelationship[] @relation("RelationshipSource")
  targetRelationships AnatomyRelationship[] @relation("RelationshipTarget")
  sourceRefs     AnatomySourceRef[]
  learningProgress LearningProgress[]
  correctionFlags AnatomyCorrectionFlag[]
  createdBy      User?                  @relation("AnatomyTermCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?                  @relation("AnatomyTermUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([kind, status])
}

model AnatomyAlias {
  id        String      @id @default(cuid())
  termId    String
  alias     String
  createdAt DateTime    @default(now())
  term      AnatomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([termId, alias])
}

model AnatomyRelationship {
  id               String      @id @default(cuid())
  sourceTermId     String
  relationshipType String
  targetTermId     String
  details          Json        @default("{}")
  createdAt        DateTime    @default(now())
  sourceTerm       AnatomyTerm @relation("RelationshipSource", fields: [sourceTermId], references: [id], onDelete: Cascade)
  targetTerm       AnatomyTerm @relation("RelationshipTarget", fields: [targetTermId], references: [id], onDelete: Cascade)

  @@unique([sourceTermId, relationshipType, targetTermId])
}

model AnatomySource {
  id          String             @id @default(cuid())
  slug        String             @unique
  label       String
  url         String?
  license     String?
  attribution String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  refs        AnatomySourceRef[]
}

model AnatomySourceRef {
  id           String        @id @default(cuid())
  termId       String
  sourceId     String
  citationNote String?
  createdAt    DateTime      @default(now())
  term         AnatomyTerm   @relation(fields: [termId], references: [id], onDelete: Cascade)
  source       AnatomySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([termId, sourceId])
}

model AnatomyCorrectionFlag {
  id             String               @id @default(cuid())
  termId         String?
  createdById    String
  issueType      String               @default("content")
  message        String
  status         CorrectionFlagStatus @default(OPEN)
  resolutionNote String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  term           AnatomyTerm?         @relation(fields: [termId], references: [id], onDelete: SetNull)
  createdBy      User                 @relation("CorrectionFlagCreator", fields: [createdById], references: [id], onDelete: Cascade)
  reviewedBy     User?                @relation("CorrectionFlagReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
}

model AnatomyAuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  tableName   String
  recordId    String?
  beforeValue Json?
  afterValue  Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AnatomyAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model AuthAttempt {
  id           String             @id @default(cuid())
  purpose      AuthAttemptPurpose
  key          String
  count        Int                @default(0)
  windowStart  DateTime           @default(now())
  blockedUntil DateTime?
  updatedAt    DateTime           @updatedAt

  @@unique([purpose, key])
}

model Practice {
  id                String                     @id @default(cuid())
  slug              String                     @unique
  name              String
  timezone          String                     @default("America/New_York")
  publicLocationLabel String?
  publicLatitude    Float?
  publicLongitude   Float?
  publicBookingStateSlug String?
  publicBookingSlug String?
  createdById       String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  createdBy         User?                      @relation("PracticeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  memberships       PracticeMembership[]
  clients           PracticeClient[]
  bookingPolicy     BookingPolicy?
  providerBookingPolicies ProviderBookingPolicy[]
  providerBookingCapacityRules ProviderBookingCapacityRule[]
  serviceTypes      ServiceType[]
  calendarResources CalendarResource[]
  availabilityRules TherapistAvailabilityRule[]
  availabilitySchedules CalendarAvailabilitySchedule[]
  availabilityOverrides CalendarAvailabilityOverride[]
  calendarEvents    CalendarEvent[]
  calendarBlocks    CalendarBlock[]
  appointments      Appointment[]
  bookingGroups     BookingGroup[]
  bookingWaitlistEntries BookingWaitlistEntry[]
  calendarAuditLogs CalendarAuditLog[]

  @@unique([publicBookingStateSlug, publicBookingSlug])
}

model PracticeMembership {
  id         String       @id @default(cuid())
  practiceId String
  userId     String
  role       PracticeRole @default(THERAPIST)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  practice   Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@index([userId, role])
}

model PracticeClient {
  id           String        @id @default(cuid())
  practiceId   String
  userId       String?
  displayName  String?
  email        String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  practice     Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  bookingGroups BookingGroup[]
  bookingWaitlistEntries BookingWaitlistEntry[]

  @@unique([practiceId, userId])
  @@index([userId])
}

model ServiceType {
  id              String        @id @default(cuid())
  practiceId      String
  name            String
  description     String?
  category        String?
  color           String?
  durationMinutes Int
  bufferMinutes   Int           @default(0)
  clientVisible   Boolean       @default(true)
  bookingRole     ServiceBookingRole @default(PRIMARY)
  countsTowardMassageCapacity Boolean @default(true)
  classEligible   Boolean       @default(false)
  supplies        String?
  prepNotes       String?
  intakeRequirements String?
  contraindicationNotice String?
  modality        String?
  bodyRegions     String[]       @default([])
  eligibleProviderIds String[]    @default([])
  documentationTemplateRefs Json  @default("[]")
  intakeTemplateRefs Json         @default("[]")
  contraindicationPrompts Json    @default("[]")
  cancellationPolicy String?
  noShowPolicy   String?
  depositPolicy  String?
  taxPolicy      String?
  packagePolicy  String?
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  practice        Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  appointmentServiceItems AppointmentServiceItem[]
  variants        ServiceVariant[]
  classes         CalendarClass[]

  @@index([practiceId, active])
}

model ServiceVariant {
  id                  String        @id @default(cuid())
  serviceTypeId       String
  name                String
  durationMinutes     Int
  processingMinutes   Int           @default(0)
  bufferBeforeMinutes Int           @default(0)
  bufferAfterMinutes  Int           @default(0)
  priceCents          Int?
  currency            String        @default("USD")
  active              Boolean       @default(true)
  clientVisible       Boolean       @default(true)
  sortOrder           Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  serviceType         ServiceType   @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)
  resourceRequirements ServiceVariantResource[]
  appointments        Appointment[]
  appointmentServiceItems AppointmentServiceItem[]
  classes             CalendarClass[]

  @@index([serviceTypeId, active])
}

model CalendarResource {
  id                  String        @id @default(cuid())
  practiceId          String
  name                String
  description         String?
  active              Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  practice            Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  variantRequirements ServiceVariantResource[]
  bookings            CalendarResourceBooking[]

  @@index([practiceId, active])
}

model ServiceVariantResource {
  id               String           @id @default(cuid())
  serviceVariantId String
  resourceId       String
  createdAt        DateTime         @default(now())
  serviceVariant   ServiceVariant   @relation(fields: [serviceVariantId], references: [id], onDelete: Cascade)
  resource         CalendarResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([serviceVariantId, resourceId])
  @@index([resourceId])
}

model TherapistAvailabilityRule {
  id          String    @id @default(cuid())
  practiceId  String
  therapistId String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  timezone    String    @default("America/New_York")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User      @relation("AvailabilityTherapist", fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([practiceId, therapistId, dayOfWeek])
}

model CalendarAvailabilitySchedule {
  id            String       @id @default(cuid())
  practiceId    String
  therapistId   String
  name          String
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  timezone      String       @default("America/New_York")
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  practice      Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist     User         @relation("AvailabilityScheduleTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  intervals     CalendarAvailabilityScheduleInterval[]

  @@index([practiceId, therapistId, active])
  @@index([therapistId, effectiveFrom])
}

model CalendarAvailabilityScheduleInterval {
  id          String                       @id @default(cuid())
  scheduleId  String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  active      Boolean                      @default(true)
  createdAt   DateTime                     @default(now())
  schedule    CalendarAvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, dayOfWeek])
}

model CalendarAvailabilityOverride {
  id          String                           @id @default(cuid())
  practiceId  String
  therapistId String
  date        DateTime
  kind        CalendarAvailabilityOverrideKind @default(OPEN)
  reason      String?
  timezone    String                           @default("America/New_York")
  createdById String?
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  practice    Practice                         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User                             @relation("AvailabilityOverrideTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  intervals   CalendarAvailabilityOverrideInterval[]

  @@index([practiceId, therapistId, date])
  @@index([therapistId, date])
}

model CalendarAvailabilityOverrideInterval {
  id          String                       @id @default(cuid())
  overrideId  String
  startMinute Int
  endMinute   Int
  active      Boolean                      @default(true)
  createdAt   DateTime                     @default(now())
  override    CalendarAvailabilityOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
}

model CalendarBlock {
  id          String    @id @default(cuid())
  eventId     String    @unique
  practiceId  String
  therapistId String
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User      @relation("CalendarBlockTherapist", fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([practiceId, therapistId, startsAt])
}

model Appointment {
  id               String            @id @default(cuid())
  eventId          String            @unique
  practiceId       String
  therapistId      String
  practiceClientId String
  serviceTypeId    String
  serviceVariantId String?
  bookingGroupId   String?
  bookingGroupOrder Int?
  createdById      String?
  startsAt         DateTime
  endsAt           DateTime
  status           AppointmentStatus @default(REQUESTED)
  source           AppointmentSource @default(CLIENT_REQUEST)
  requestedPressureLevel Int?
  massageCapacityMinutes Int @default(0)
  serviceName      String?
  serviceVariantName String?
  serviceCategory  String?
  serviceColor     String?
  serviceDurationMinutes Int?
  serviceProcessingMinutes Int?
  serviceBufferBeforeMinutes Int?
  serviceBufferAfterMinutes Int?
  servicePriceCents Int?
  serviceCurrency  String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  event            CalendarEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist        User              @relation("AppointmentTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  practiceClient   PracticeClient    @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  serviceType      ServiceType       @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  serviceVariant   ServiceVariant?   @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)
  bookingGroup     BookingGroup?      @relation(fields: [bookingGroupId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("AppointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  serviceItems     AppointmentServiceItem[]

  @@index([practiceId, startsAt])
  @@index([therapistId, startsAt])
  @@index([practiceClientId, startsAt])
  @@index([serviceVariantId])
  @@index([bookingGroupId, bookingGroupOrder])
}

model AppointmentServiceItem {
  id               String            @id @default(cuid())
  appointmentId    String
  serviceTypeId    String?
  serviceVariantId String?
  sortOrder        Int               @default(0)
  requestedPressureLevel Int?
  massageCapacityMinutes Int @default(0)
  serviceName      String?
  serviceVariantName String?
  serviceCategory  String?
  serviceColor     String?
  serviceDurationMinutes Int?
  serviceProcessingMinutes Int?
  serviceBufferBeforeMinutes Int?
  serviceBufferAfterMinutes Int?
  servicePriceCents Int?
  serviceCurrency  String?
  createdAt        DateTime          @default(now())
  appointment      Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceType      ServiceType?      @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  serviceVariant   ServiceVariant?   @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)

  @@index([appointmentId, sortOrder])
  @@index([serviceVariantId])
}

model BookingPolicy {
  id                    String                @id @default(cuid())
  practiceId            String                @unique
  enabled               Boolean               @default(true)
  approvalMode          BookingApprovalMode   @default(MANUAL)
  minNoticeMinutes      Int                   @default(0)
  maxAdvanceDays        Int                   @default(7)
  dailyAppointmentLimit Int?
  anyProviderEnabled    Boolean               @default(true)
  teamSequencingEnabled Boolean               @default(true)
  staffVisibility       BookingStaffVisibility @default(PUBLIC_LABELS)
  dualTimezoneDisplay   Boolean               @default(true)
  proximityNoticeEnabled Boolean              @default(false)
  proximityRadiusMiles  Int                   @default(45)
  requireClientAccount  Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  practice              Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model ProviderBookingPolicy {
  id                    String   @id @default(cuid())
  practiceId            String
  providerUserId        String
  publiclyBookable      Boolean  @default(true)
  displayLabel          String?
  minRestMinutes        Int      @default(0)
  dailyAppointmentLimit Int?
  weeklyAppointmentLimit Int?
  requireClientAccount  Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider              User     @relation("ProviderBookingPolicyProvider", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@unique([practiceId, providerUserId])
  @@index([providerUserId])
}

model ProviderBookingCapacityRule {
  id             String                @id @default(cuid())
  practiceId     String
  providerUserId String
  period         BookingCapacityPeriod
  dayOfWeek      Int?
  pressureLevel  Int                   @default(0)
  maxMinutes     Int
  active         Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  practice       Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider       User                  @relation("ProviderBookingCapacityRuleProvider", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@index([practiceId, providerUserId, active])
  @@index([providerUserId, period, dayOfWeek])
}

model BookingGroup {
  id                     String             @id @default(cuid())
  practiceId             String
  practiceClientId       String
  createdById            String?
  requestedPressureLevel Int
  status                 BookingGroupStatus @default(REQUESTED)
  source                 AppointmentSource  @default(CLIENT_REQUEST)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  practice               Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceClient         PracticeClient     @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  createdBy              User?              @relation("BookingGroupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  appointments           Appointment[]
  convertedWaitlistEntry BookingWaitlistEntry?

  @@index([practiceId, status, createdAt])
  @@index([practiceClientId, createdAt])
}

model BookingWaitlistEntry {
  id                     String                @id @default(cuid())
  practiceId             String
  practiceClientId       String
  createdById            String?
  status                 BookingWaitlistStatus @default(OPEN)
  requestedPressureLevel Int
  primaryServiceVariantId String?
  addOnServiceVariantIds String[]              @default([])
  preferredProviderId    String?
  preferredStartsAt      DateTime?
  convertedBookingGroupId String?              @unique
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  practice               Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceClient         PracticeClient        @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  createdBy              User?                 @relation("BookingWaitlistCreator", fields: [createdById], references: [id], onDelete: SetNull)
  convertedBookingGroup  BookingGroup?         @relation(fields: [convertedBookingGroupId], references: [id], onDelete: SetNull)

  @@index([practiceId, status, createdAt])
  @@index([practiceClientId, createdAt])
}

model CalendarEvent {
  id                 String                  @id @default(cuid())
  practiceId         String
  ownerUserId        String?
  createdById        String?
  kind               CalendarEventKind
  title              String
  startsAt           DateTime
  endsAt             DateTime
  timezone           String                  @default("America/New_York")
  visibility         CalendarEventVisibility @default(PRACTICE)
  status             CalendarEventStatus     @default(ACTIVE)
  blocksAvailability Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  practice           Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  owner              User?                   @relation("CalendarEventOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy          User?                   @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  appointment        Appointment?
  personalBlock      CalendarBlock?
  class              CalendarClass?
  reminder           CalendarReminder?
  resourceBookings   CalendarResourceBooking[]
  auditLogs          CalendarAuditLog[]
  notificationIntents CalendarNotificationIntent[]

  @@index([practiceId, startsAt])
  @@index([ownerUserId, startsAt])
  @@index([kind, status])
}

model CalendarClass {
  id               String                        @id @default(cuid())
  eventId          String                        @unique
  instructorId     String
  serviceTypeId    String?
  serviceVariantId String?
  capacity         Int
  enrollmentStatus CalendarClassEnrollmentStatus @default(OPEN)
  roomResource     String?
  clientVisible    Boolean                       @default(false)
  serviceName      String?
  serviceVariantName String?
  serviceCategory  String?
  serviceColor     String?
  serviceDurationMinutes Int?
  serviceProcessingMinutes Int?
  serviceBufferBeforeMinutes Int?
  serviceBufferAfterMinutes Int?
  servicePriceCents Int?
  serviceCurrency  String?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  event            CalendarEvent                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  instructor       User                          @relation("CalendarClassInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  serviceType      ServiceType?                  @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  serviceVariant   ServiceVariant?               @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)

  @@index([instructorId])
  @@index([enrollmentStatus])
  @@index([serviceVariantId])
}

model CalendarResourceBooking {
  id         String           @id @default(cuid())
  eventId    String
  resourceId String
  startsAt   DateTime
  endsAt     DateTime
  createdAt  DateTime         @default(now())
  event      CalendarEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  resource   CalendarResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([eventId, resourceId])
  @@index([resourceId, startsAt])
}

model CalendarReminder {
  id          String        @id @default(cuid())
  eventId     String        @unique
  relatedKind String?
  relatedId   String?
  payload     Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  event       CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([relatedKind, relatedId])
}

model CalendarAuditLog {
  id          String        @id @default(cuid())
  practiceId  String
  eventId     String?
  actorUserId String?
  action      String
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  practice    Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  event       CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  actor       User?         @relation("CalendarAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([practiceId, createdAt])
  @@index([eventId, createdAt])
  @@index([actorUserId, createdAt])
}

model CalendarNotificationIntent {
  id              String                     @id @default(cuid())
  eventId          String
  actorUserId      String?
  recipientUserId  String
  action           String
  channel          CalendarNotificationChannel @default(INTERNAL)
  deliveryStatus   CalendarNotificationStatus  @default(PENDING)
  payload          Json                       @default("{}")
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  event            CalendarEvent              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor            User?                      @relation("CalendarNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  recipient        User                       @relation("CalendarNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([recipientUserId, deliveryStatus])
  @@index([actorUserId, createdAt])
}

model StripeCustomer {
  id               String   @id @default(cuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model MembershipSubscription {
  id                       String          @id @default(cuid())
  userId                   String
  stripeSubscriptionId     String          @unique
  stripeCustomerId         String
  status                   String
  membershipLevel          MembershipLevel
  stripePriceId            String?
  stripeProductId          String?
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean         @default(false)
  canceledAt               DateTime?
  couponId                 String?
  metadata                 Json            @default("{}")
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  user                     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([membershipLevel, status])
  @@index([stripeCustomerId])
}

model StudentAccess {
  userId                         String              @id
  studentStartDate               DateTime
  studentAccessExpiresAt         DateTime
  studentStatus                  StudentAccessStatus @default(ACTIVE)
  eligibleForTherapistDiscount   Boolean             @default(true)
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt
  user                           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([studentStatus, studentAccessExpiresAt])
}
