  serviceVariant   ServiceVariant   @relation(fields: [serviceVariantId], references: [id], onDelete: Cascade)
  resource         CalendarResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([serviceVariantId, resourceId])
  @@index([resourceId])
}

model TherapistAvailabilityRule {
  id          String    @id @default(cuid())
  practiceId  String
  therapistId String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  timezone    String    @default("America/New_York")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User      @relation("AvailabilityTherapist", fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([practiceId, therapistId, dayOfWeek])
}

model CalendarAvailabilitySchedule {
  id            String       @id @default(cuid())
  practiceId    String
  therapistId   String
  name          String
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  timezone      String       @default("America/New_York")
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  practice      Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist     User         @relation("AvailabilityScheduleTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  intervals     CalendarAvailabilityScheduleInterval[]

  @@index([practiceId, therapistId, active])
  @@index([therapistId, effectiveFrom])
}

model CalendarAvailabilityScheduleInterval {
  id          String                       @id @default(cuid())
  scheduleId  String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  active      Boolean                      @default(true)
  createdAt   DateTime                     @default(now())
  schedule    CalendarAvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, dayOfWeek])
}

model CalendarAvailabilityOverride {
  id          String                           @id @default(cuid())
  practiceId  String
  therapistId String
  date        DateTime
  kind        CalendarAvailabilityOverrideKind @default(OPEN)
  reason      String?
  timezone    String                           @default("America/New_York")
  createdById String?
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  practice    Practice                         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User                             @relation("AvailabilityOverrideTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  intervals   CalendarAvailabilityOverrideInterval[]

  @@index([practiceId, therapistId, date])
  @@index([therapistId, date])
}

model CalendarAvailabilityOverrideInterval {
  id          String                       @id @default(cuid())
  overrideId  String
  startMinute Int
  endMinute   Int
  active      Boolean                      @default(true)
  createdAt   DateTime                     @default(now())
  override    CalendarAvailabilityOverride @relation(fields: [overrideId], references: [id], onDelete: Cascade)

  @@index([overrideId])
}

model CalendarBlock {
  id          String    @id @default(cuid())
  eventId     String    @unique
  practiceId  String
  therapistId String
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User      @relation("CalendarBlockTherapist", fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([practiceId, therapistId, startsAt])
}

model Appointment {
  id               String            @id @default(cuid())
  eventId          String            @unique
  practiceId       String
  therapistId      String
  practiceClientId String
  serviceTypeId    String
  serviceVariantId String?
  bookingGroupId   String?
  bookingGroupOrder Int?
  createdById      String?
  startsAt         DateTime
  endsAt           DateTime
  status           AppointmentStatus @default(REQUESTED)
  source           AppointmentSource @default(CLIENT_REQUEST)
  requestedPressureLevel Int?
  massageCapacityMinutes Int @default(0)
  serviceName      String?
  serviceVariantName String?
  serviceCategory  String?
  serviceColor     String?
  serviceDurationMinutes Int?
  serviceProcessingMinutes Int?
  serviceBufferBeforeMinutes Int?
  serviceBufferAfterMinutes Int?
  servicePriceCents Int?
  serviceCurrency  String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  event            CalendarEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist        User              @relation("AppointmentTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  practiceClient   PracticeClient    @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  serviceType      ServiceType       @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  serviceVariant   ServiceVariant?   @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)
  bookingGroup     BookingGroup?      @relation(fields: [bookingGroupId], references: [id], onDelete: SetNull)
  createdBy        User?             @relation("AppointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  serviceItems     AppointmentServiceItem[]

  @@index([practiceId, startsAt])
  @@index([therapistId, startsAt])
  @@index([practiceClientId, startsAt])
  @@index([serviceVariantId])
  @@index([bookingGroupId, bookingGroupOrder])
}

model AppointmentServiceItem {
  id               String            @id @default(cuid())
  appointmentId    String
  serviceTypeId    String?
  serviceVariantId String?
  sortOrder        Int               @default(0)
  requestedPressureLevel Int?
  massageCapacityMinutes Int @default(0)
  serviceName      String?
  serviceVariantName String?
  serviceCategory  String?
  serviceColor     String?
  serviceDurationMinutes Int?
  serviceProcessingMinutes Int?
  serviceBufferBeforeMinutes Int?
  serviceBufferAfterMinutes Int?
  servicePriceCents Int?
  serviceCurrency  String?
  createdAt        DateTime          @default(now())
  appointment      Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceType      ServiceType?      @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  serviceVariant   ServiceVariant?   @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)

  @@index([appointmentId, sortOrder])
  @@index([serviceVariantId])
}

model BookingPolicy {
  id                    String                @id @default(cuid())
  practiceId            String                @unique
  enabled               Boolean               @default(true)
  approvalMode          BookingApprovalMode   @default(MANUAL)
  minNoticeMinutes      Int                   @default(0)
  maxAdvanceDays        Int                   @default(7)
  dailyAppointmentLimit Int?
  anyProviderEnabled    Boolean               @default(true)
  teamSequencingEnabled Boolean               @default(true)
  staffVisibility       BookingStaffVisibility @default(PUBLIC_LABELS)
  dualTimezoneDisplay   Boolean               @default(true)
  proximityNoticeEnabled Boolean              @default(false)
  proximityRadiusMiles  Int                   @default(45)
  requireClientAccount  Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  practice              Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model ProviderBookingPolicy {
  id                    String   @id @default(cuid())
  practiceId            String
  providerUserId        String
  publiclyBookable      Boolean  @default(true)
  displayLabel          String?
  minRestMinutes        Int      @default(0)
  dailyAppointmentLimit Int?
  weeklyAppointmentLimit Int?
  requireClientAccount  Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  practice              Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider              User     @relation("ProviderBookingPolicyProvider", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@unique([practiceId, providerUserId])
  @@index([providerUserId])
}

model ProviderBookingCapacityRule {
  id             String                @id @default(cuid())
  practiceId     String
  providerUserId String
  period         BookingCapacityPeriod
  dayOfWeek      Int?
  pressureLevel  Int                   @default(0)
  maxMinutes     Int
  active         Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  practice       Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider       User                  @relation("ProviderBookingCapacityRuleProvider", fields: [providerUserId], references: [id], onDelete: Cascade)

  @@index([practiceId, providerUserId, active])
  @@index([providerUserId, period, dayOfWeek])
}

model BookingGroup {
  id                     String             @id @default(cuid())
  practiceId             String
  practiceClientId       String
  createdById            String?
  requestedPressureLevel Int
  status                 BookingGroupStatus @default(REQUESTED)
  source                 AppointmentSource  @default(CLIENT_REQUEST)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  practice               Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceClient         PracticeClient     @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  createdBy              User?              @relation("BookingGroupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  appointments           Appointment[]
  convertedWaitlistEntry BookingWaitlistEntry?

  @@index([practiceId, status, createdAt])
  @@index([practiceClientId, createdAt])
}

model BookingWaitlistEntry {
  id                     String                @id @default(cuid())
  practiceId             String
  practiceClientId       String
  createdById            String?
  status                 BookingWaitlistStatus @default(OPEN)
  requestedPressureLevel Int
  primaryServiceVariantId String?
  addOnServiceVariantIds String[]              @default([])
  preferredProviderId    String?
  preferredStartsAt      DateTime?
  convertedBookingGroupId String?              @unique
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  practice               Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  practiceClient         PracticeClient        @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  createdBy              User?                 @relation("BookingWaitlistCreator", fields: [createdById], references: [id], onDelete: SetNull)
  convertedBookingGroup  BookingGroup?         @relation(fields: [convertedBookingGroupId], references: [id], onDelete: SetNull)

  @@index([practiceId, status, createdAt])
  @@index([practiceClientId, createdAt])
}

model CalendarEvent {
  id                 String                  @id @default(cuid())
  practiceId         String
  ownerUserId        String?
  createdById        String?
  kind               CalendarEventKind
  title              String
  startsAt           DateTime
  endsAt             DateTime
  timezone           String                  @default("America/New_York")
  visibility         CalendarEventVisibility @default(PRACTICE)
  status             CalendarEventStatus     @default(ACTIVE)
  blocksAvailability Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  practice           Practice                @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  owner              User?                   @relation("CalendarEventOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy          User?                   @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  appointment        Appointment?
  personalBlock      CalendarBlock?
  class              CalendarClass?
  reminder           CalendarReminder?
  resourceBookings   CalendarResourceBooking[]
  auditLogs          CalendarAuditLog[]
  notificationIntents CalendarNotificationIntent[]
  externalCalendarLinks ExternalCalendarEventLink[]

  @@index([practiceId, startsAt])
  @@index([ownerUserId, startsAt])
  @@index([kind, status])
}

model CalendarClass {
  id               String                        @id @default(cuid())
  eventId          String                        @unique
  instructorId     String
  serviceTypeId    String?
  serviceVariantId String?
  capacity         Int
  enrollmentStatus CalendarClassEnrollmentStatus @default(OPEN)
  roomResource     String?
  clientVisible    Boolean                       @default(false)
  serviceName      String?
  serviceVariantName String?
  serviceCategory  String?
  serviceColor     String?
  serviceDurationMinutes Int?
  serviceProcessingMinutes Int?
  serviceBufferBeforeMinutes Int?
  serviceBufferAfterMinutes Int?
  servicePriceCents Int?
  serviceCurrency  String?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  event            CalendarEvent                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  instructor       User                          @relation("CalendarClassInstructor", fields: [instructorId], references: [id], onDelete: Cascade)
  serviceType      ServiceType?                  @relation(fields: [serviceTypeId], references: [id], onDelete: SetNull)
  serviceVariant   ServiceVariant?               @relation(fields: [serviceVariantId], references: [id], onDelete: SetNull)

  @@index([instructorId])
  @@index([enrollmentStatus])
  @@index([serviceVariantId])
}

model CalendarResourceBooking {
  id         String           @id @default(cuid())
  eventId    String
  resourceId String
  startsAt   DateTime
  endsAt     DateTime
  createdAt  DateTime         @default(now())
  event      CalendarEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  resource   CalendarResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([eventId, resourceId])
  @@index([resourceId, startsAt])
}

model CalendarReminder {
  id          String        @id @default(cuid())
  eventId     String        @unique
  relatedKind String?
  relatedId   String?
  payload     Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  event       CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([relatedKind, relatedId])
}

model CalendarAuditLog {
  id          String        @id @default(cuid())
  practiceId  String
  eventId     String?
  actorUserId String?
  action      String
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  practice    Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  event       CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  actor       User?         @relation("CalendarAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([practiceId, createdAt])
  @@index([eventId, createdAt])
  @@index([actorUserId, createdAt])
}

model CalendarNotificationIntent {
  id              String                     @id @default(cuid())
  eventId          String
  actorUserId      String?
  recipientUserId  String
  action           String
  channel          CalendarNotificationChannel @default(INTERNAL)
  deliveryStatus   CalendarNotificationStatus  @default(PENDING)
  payload          Json                       @default("{}")
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  event            CalendarEvent              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor            User?                      @relation("CalendarNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  recipient        User                       @relation("CalendarNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([recipientUserId, deliveryStatus])
  @@index([actorUserId, createdAt])
}

model CalendarConnection {
  id                         String                   @id @default(cuid())
  userId                     String
  provider                   ExternalCalendarProvider
  providerAccountId          String
  accountEmail               String?
  encryptedRefreshToken      String                   @db.Text
  encryptedAccessToken       String?                  @db.Text
  accessTokenExpiresAt       DateTime?
  grantedScopes              String                   @default("")
  status                     CalendarConnectionStatus @default(ACTIVE)
  statusReason               String?
  dedicatedCalendarId        String?
  dedicatedCalendarSummary   String?
  lastSyncedAt               DateTime?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  user                       User                     @relation("CalendarConnectionUser", fields: [userId], references: [id], onDelete: Cascade)
  sources                    ExternalCalendarSource[]
  busyBlocks                 ExternalCalendarBusyBlock[]
  eventLinks                 ExternalCalendarEventLink[]
  syncRuns                   CalendarSyncRun[]

  @@unique([userId, provider, providerAccountId])
  @@unique([userId, provider], where: { status: "ACTIVE" }, map: "CalendarConnection_one_active_provider_key")
  @@index([userId, status])
  @@index([provider, status])
}

model ExternalCalendarSource {
  id                       String             @id @default(cuid())
  connectionId             String
  providerCalendarId       String
  label                    String?
  timezone                 String?
  selectedForBusySync      Boolean            @default(false)
  syncToken                String?            @db.Text
  lastFullSyncAt           DateTime?
  lastIncrementalSyncAt    DateTime?
  lastErrorCode            String?
  lastErrorMessage         String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  connection               CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  busyBlocks               ExternalCalendarBusyBlock[]
  syncRuns                 CalendarSyncRun[]

  @@unique([connectionId, providerCalendarId])
  @@index([connectionId, selectedForBusySync])
}

model ExternalCalendarBusyBlock {
  id                  String                     @id @default(cuid())
  connectionId        String
  sourceId            String
  ownerUserId         String
  provider            ExternalCalendarProvider
  providerCalendarId  String
  providerEventId     String
  providerEventEtag   String?
  startsAt            DateTime
  endsAt              DateTime
  timezone            String?
  allDay              Boolean                    @default(false)
  transparency        String?
  status              ExternalCalendarBusyStatus @default(BUSY)
  cancelledAt         DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  connection          CalendarConnection         @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  source              ExternalCalendarSource     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  owner               User                       @relation("ExternalCalendarBusyBlockOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([sourceId, providerEventId])
  @@index([ownerUserId, startsAt, endsAt, status])
  @@index([connectionId, updatedAt])
}

model ExternalCalendarEventLink {
  id                  String                   @id @default(cuid())
  connectionId        String
  calendarEventId     String
  provider            ExternalCalendarProvider
  providerCalendarId  String
  providerEventId     String?
  providerEventEtag   String?
  lastPushedAt        DateTime?
  lastErrorCode       String?
  lastErrorMessage    String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  connection          CalendarConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  calendarEvent       CalendarEvent            @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)

  @@unique([connectionId, calendarEventId])
  @@unique([provider, providerCalendarId, providerEventId])
  @@index([calendarEventId])
}

model CalendarSyncRun {
  id                String                   @id @default(cuid())
  connectionId      String
  sourceId          String?
  direction         CalendarSyncRunDirection
  status            CalendarSyncRunStatus
  startedAt         DateTime                 @default(now())
  finishedAt        DateTime?
  windowStart       DateTime?
  windowEnd         DateTime?
  itemsSeen         Int                      @default(0)
  itemsChanged      Int                      @default(0)
  errorCode         String?
  errorMessage      String?
  connection        CalendarConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  source            ExternalCalendarSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([connectionId, startedAt])
  @@index([sourceId, startedAt])
  @@index([status, startedAt])
}

model StripeCustomer {
  id               String   @id @default(cuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
}

model MembershipSubscription {
  id                       String          @id @default(cuid())
  userId                   String
  stripeSubscriptionId     String          @unique
  stripeCustomerId         String
  status                   String
  membershipLevel          MembershipLevel
  stripePriceId            String?
  stripeProductId          String?
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean         @default(false)
  canceledAt               DateTime?
  couponId                 String?
  metadata                 Json            @default("{}")
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  user                     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([membershipLevel, status])
  @@index([stripeCustomerId])
}

model StudentAccess {
  userId                         String              @id
  studentStartDate               DateTime
  studentAccessExpiresAt         DateTime
  studentStatus                  StudentAccessStatus @default(ACTIVE)
  eligibleForTherapistDiscount   Boolean             @default(true)
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt
  user                           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([studentStatus, studentAccessExpiresAt])
}
