generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  STUDENT
  LICENSED_THERAPIST
  CLIENT
  EDITOR
  ADMIN
}

enum AuthAttemptPurpose {
  LOGIN
  REGISTER
  PASSWORD_RESET
  TWO_FACTOR
}

enum AnatomyKind {
  SYSTEM
  ORGAN
  TISSUE
  BONE
  MUSCLE
  JOINT
  NERVE
  VESSEL
  LIGAMENT
  TENDON
  CELL
  OTHER
}

enum AnatomyDifficulty {
  EASY
  MEDIUM
  HARD
}

enum AnatomyStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ProgressStatus {
  STARTED
  PRACTICING
  MASTERED
  SKIPPED
}

enum CorrectionFlagStatus {
  OPEN
  RESOLVED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  EXPIRED
  REJECTED
  REVOKED
}

enum CredentialKind {
  MASSAGE_LICENSE
  STUDENT_ENROLLMENT
  INTERSTATE_MASSAGE_COMPACT
  MANUAL_REVIEW
}

enum VerificationSourceType {
  SELF_ATTESTATION
  STATE_LICENSE_LOOKUP
  DOCUMENT_REVIEW
  MANUAL_REVIEW
  COMPACT_REGISTRY
}

enum JurisdictionSupportStatus {
  ADAPTER_AVAILABLE
  PUBLIC_LOOKUP_AVAILABLE
  MANUAL_REVIEW_REQUIRED
  PLANNED
  UNSUPPORTED
}

enum TherapistClientStatus {
  INVITED
  ACTIVE
  PAUSED
  REVOKED
}

enum ClinicalArtifactKind {
  SOAP_NOTE
  INTAKE_FORM
  PAIN_JOURNAL
  SENSATION_JOURNAL
  INCIDENT_JOURNAL
  ROM_MEASUREMENT
  MOVEMENT_SESSION
}

enum ClinicalArtifactStatus {
  LOCAL_ONLY
  DRAFT
  FINALIZED
  RELEASE_REQUESTED
  RELEASED
  ARCHIVED
}

enum PracticeRole {
  OWNER
  THERAPIST
  STAFF
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  CLIENT_REQUEST
  THERAPIST_CREATED
}

model User {
  id                    String                   @id @default(cuid())
  name                  String?
  email                 String?                  @unique
  emailVerified         DateTime?
  image                 String?
  accounts              Account[]
  sessions              Session[]
  roles                 UserRole[]
  grantedRoles          UserRole[]                @relation("GrantedUserRoles")
  profile               UserProfile?
  preference            UserPreference?
  passwordCredential    PasswordCredential?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  twoFactorSecret       TwoFactorSecret?
  backupCodes           BackupCode[]
  learningProgress      LearningProgress[]
  achievements          Achievement[]
  noteTemplates         NoteTemplate[]
  formTemplates         FormTemplate[]
  documentationPreference DocumentationPreference?
  credentialVerifications CredentialVerification[] @relation("CredentialVerificationUser")
  verifiedCredentialClaims VerifiedCredentialClaim[]
  reviewedCredentialVerifications CredentialVerification[] @relation("CredentialVerificationReviewer")
  therapistRelationships TherapistClientRelationship[] @relation("TherapistClientRelationships")
  clientRelationships   TherapistClientRelationship[] @relation("ClientClientRelationships")
  authoredClinicalArtifactManifests ClinicalArtifactManifest[] @relation("ClinicalArtifactAuthor")
  subjectClinicalArtifactManifests ClinicalArtifactManifest[] @relation("ClinicalArtifactSubject")
  therapistClinicalArtifactManifests ClinicalArtifactManifest[] @relation("ClinicalArtifactTherapist")
  clinicalAuditLogs     ClinicalAccessAuditLog[]  @relation("ClinicalAuditActor")
  clinicalAuditTargets  ClinicalAccessAuditLog[]  @relation("ClinicalAuditTarget")
  correctionFlags       AnatomyCorrectionFlag[]  @relation("CorrectionFlagCreator")
  reviewedFlags         AnatomyCorrectionFlag[]  @relation("CorrectionFlagReviewer")
  createdTerms          AnatomyTerm[]            @relation("AnatomyTermCreator")
  updatedTerms          AnatomyTerm[]            @relation("AnatomyTermUpdater")
  auditLogs             AnatomyAuditLog[]         @relation("AnatomyAuditActor")
  createdPractices      Practice[]               @relation("PracticeCreator")
  practiceMemberships   PracticeMembership[]
  practiceClients       PracticeClient[]
  availabilityRules     TherapistAvailabilityRule[] @relation("AvailabilityTherapist")
  calendarBlocks        CalendarBlock[]          @relation("CalendarBlockTherapist")
  appointmentsAsTherapist Appointment[]           @relation("AppointmentTherapist")
  createdAppointments   Appointment[]            @relation("AppointmentCreator")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id          String    @id @default(cuid())
  userId      String
  email       String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorSecret {
  id              String    @id @default(cuid())
  userId          String    @unique
  encryptedSecret String
  enabledAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserRole {
  id          String             @id @default(cuid())
  userId      String
  role        Role               @default(USER)
  status      VerificationStatus @default(VERIFIED)
  source      String             @default("system")
  metadata    Json               @default("{}")
  verifiedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  grantedById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User?              @relation("GrantedUserRoles", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([role, status])
  @@index([userId, status])
}

model UserProfile {
  userId              String   @id
  displayName         String?
  therapistName       String?
  therapistLocation   String?
  licenseNumber       String?
  licenseOrganization String?
  npiNumber           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CredentialVerification {
  id                  String                 @id @default(cuid())
  userId              String
  kind                CredentialKind
  role                Role?
  status              VerificationStatus     @default(PENDING)
  jurisdictionCode    String?
  credentialNumber    String?
  issuingAuthority    String?
  displayLabel        String?
  sourceType          VerificationSourceType @default(SELF_ATTESTATION)
  sourceUrl           String?
  evidenceDescription String?
  verificationPayload Json                   @default("{}")
  checkedAt           DateTime?
  verifiedAt          DateTime?
  expiresAt           DateTime?
  rejectedAt          DateTime?
  revokedAt           DateTime?
  reviewedById        String?
  reviewNote          String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  user                User                   @relation("CredentialVerificationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer            User?                  @relation("CredentialVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([userId, kind, jurisdictionCode, credentialNumber])
  @@index([userId, kind, status])
  @@index([jurisdictionCode, status])
  @@index([role, status])
}

model VerifiedCredentialClaim {
  id                         String         @id @default(cuid())
  userId                     String
  kind                       CredentialKind
  jurisdictionCode           String
  normalizedCredentialNumber String
  credentialVerificationId   String?
  source                     String
  claimedAt                  DateTime       @default(now())
  expiresAt                  DateTime?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  user                       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kind, jurisdictionCode, normalizedCredentialNumber])
  @@index([userId, kind])
  @@index([credentialVerificationId])
}

model JurisdictionVerifier {
  id              String                    @id @default(cuid())
  jurisdictionCode String                   @unique
  jurisdictionName String
  countryCode     String                    @default("US")
  massageBoardName String?
  lookupUrl       String?
  supportStatus   JurisdictionSupportStatus @default(MANUAL_REVIEW_REQUIRED)
  compactEligible Boolean                   @default(false)
  compactStatus   String?
  notes           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([countryCode, supportStatus])
}

model TherapistClientRelationship {
  id            String                 @id @default(cuid())
  therapistUserId String
  clientUserId  String?
  clientEmail   String?
  status        TherapistClientStatus  @default(INVITED)
  invitedAt     DateTime               @default(now())
  acceptedAt    DateTime?
  pausedAt      DateTime?
  revokedAt     DateTime?
  metadata      Json                   @default("{}")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  therapist     User                   @relation("TherapistClientRelationships", fields: [therapistUserId], references: [id], onDelete: Cascade)
  client        User?                  @relation("ClientClientRelationships", fields: [clientUserId], references: [id], onDelete: SetNull)
  clinicalArtifactManifests ClinicalArtifactManifest[]

  @@unique([therapistUserId, clientUserId])
  @@index([therapistUserId, status])
  @@index([clientUserId, status])
  @@index([clientEmail])
}

model ClinicalArtifactManifest {
  id             String                 @id @default(cuid())
  kind           ClinicalArtifactKind
  status         ClinicalArtifactStatus @default(LOCAL_ONLY)
  schemaVersion  Int                    @default(1)
  localDocumentId String
  authorUserId   String?
  subjectUserId  String?
  therapistUserId String?
  relationshipId String?
  finalizedAt    DateTime?
  releaseRequestedAt DateTime?
  releasedAt     DateTime?
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  author         User?                  @relation("ClinicalArtifactAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  subject        User?                  @relation("ClinicalArtifactSubject", fields: [subjectUserId], references: [id], onDelete: SetNull)
  therapist      User?                  @relation("ClinicalArtifactTherapist", fields: [therapistUserId], references: [id], onDelete: SetNull)
  relationship   TherapistClientRelationship? @relation(fields: [relationshipId], references: [id], onDelete: SetNull)
  auditLogs      ClinicalAccessAuditLog[]

  @@unique([localDocumentId])
  @@index([authorUserId, kind])
  @@index([subjectUserId, kind])
  @@index([therapistUserId, status])
  @@index([relationshipId, status])
}

model ClinicalAccessAuditLog {
  id                 String   @id @default(cuid())
  actorUserId        String?
  targetUserId       String?
  clinicalArtifactId String?
  action             String
  metadata           Json     @default("{}")
  createdAt          DateTime @default(now())
  actor              User?    @relation("ClinicalAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  target             User?    @relation("ClinicalAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  clinicalArtifact   ClinicalArtifactManifest? @relation(fields: [clinicalArtifactId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([clinicalArtifactId, createdAt])
  @@index([action, createdAt])
}

model UserPreference {
  userId            String   @id
  version           Int      @default(1)
  appSettings       Json     @default("{}")
  chimerSettings    Json     @default("{}")
  anatomimeSettings Json     @default("{}")
  notePreferences   Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DocumentationPreference {
  userId      String   @id
  version     Int      @default(1)
  preferences Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NoteTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  kind      String
  content   Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

model FormTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  kind      String
  schema    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

model LearningProgress {
  id            String         @id @default(cuid())
  userId        String
  anatomyTermId String?
  tool          String
  status        ProgressStatus @default(STARTED)
  score         Int?
  metadata      Json           @default("{}")
  lastSeenAt    DateTime       @default(now())
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  anatomyTerm   AnatomyTerm?   @relation(fields: [anatomyTermId], references: [id], onDelete: Cascade)

  @@unique([userId, anatomyTermId, tool])
  @@index([userId, tool])
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  key       String
  tool      String
  metadata  Json     @default("{}")
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, tool])
}

model AnatomyTerm {
  id             String                 @id @default(cuid())
  slug           String                 @unique
  kind           AnatomyKind
  preferredName  String
  summary        String?
  regions        String[]               @default([])
  bodySystems    String[]               @default([])
  difficulty     AnatomyDifficulty      @default(MEDIUM)
  status         AnatomyStatus          @default(DRAFT)
  createdById    String?
  updatedById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  aliases        AnatomyAlias[]
  sourceRelationships AnatomyRelationship[] @relation("RelationshipSource")
  targetRelationships AnatomyRelationship[] @relation("RelationshipTarget")
  sourceRefs     AnatomySourceRef[]
  learningProgress LearningProgress[]
  correctionFlags AnatomyCorrectionFlag[]
  createdBy      User?                  @relation("AnatomyTermCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?                  @relation("AnatomyTermUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([kind, status])
}

model AnatomyAlias {
  id        String      @id @default(cuid())
  termId    String
  alias     String
  createdAt DateTime    @default(now())
  term      AnatomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([termId, alias])
}

model AnatomyRelationship {
  id               String      @id @default(cuid())
  sourceTermId     String
  relationshipType String
  targetTermId     String
  details          Json        @default("{}")
  createdAt        DateTime    @default(now())
  sourceTerm       AnatomyTerm @relation("RelationshipSource", fields: [sourceTermId], references: [id], onDelete: Cascade)
  targetTerm       AnatomyTerm @relation("RelationshipTarget", fields: [targetTermId], references: [id], onDelete: Cascade)

  @@unique([sourceTermId, relationshipType, targetTermId])
}

model AnatomySource {
  id          String             @id @default(cuid())
  slug        String             @unique
  label       String
  url         String?
  license     String?
  attribution String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  refs        AnatomySourceRef[]
}

model AnatomySourceRef {
  id           String        @id @default(cuid())
  termId       String
  sourceId     String
  citationNote String?
  createdAt    DateTime      @default(now())
  term         AnatomyTerm   @relation(fields: [termId], references: [id], onDelete: Cascade)
  source       AnatomySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([termId, sourceId])
}

model AnatomyCorrectionFlag {
  id             String               @id @default(cuid())
  termId         String?
  createdById    String
  issueType      String               @default("content")
  message        String
  status         CorrectionFlagStatus @default(OPEN)
  resolutionNote String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  term           AnatomyTerm?         @relation(fields: [termId], references: [id], onDelete: SetNull)
  createdBy      User                 @relation("CorrectionFlagCreator", fields: [createdById], references: [id], onDelete: Cascade)
  reviewedBy     User?                @relation("CorrectionFlagReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
}

model AnatomyAuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  tableName   String
  recordId    String?
  beforeValue Json?
  afterValue  Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AnatomyAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model AuthAttempt {
  id           String             @id @default(cuid())
  purpose      AuthAttemptPurpose
  key          String
  count        Int                @default(0)
  windowStart  DateTime           @default(now())
  blockedUntil DateTime?
  updatedAt    DateTime           @updatedAt

  @@unique([purpose, key])
}

model Practice {
  id                String                     @id @default(cuid())
  slug              String                     @unique
  name              String
  timezone          String                     @default("America/New_York")
  createdById       String?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  createdBy         User?                      @relation("PracticeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  memberships       PracticeMembership[]
  clients           PracticeClient[]
  serviceTypes      ServiceType[]
  availabilityRules TherapistAvailabilityRule[]
  calendarBlocks    CalendarBlock[]
  appointments      Appointment[]
}

model PracticeMembership {
  id         String       @id @default(cuid())
  practiceId String
  userId     String
  role       PracticeRole @default(THERAPIST)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  practice   Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId])
  @@index([userId, role])
}

model PracticeClient {
  id           String        @id @default(cuid())
  practiceId   String
  userId       String
  displayName  String?
  email        String?
  phone        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  practice     Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([practiceId, userId])
  @@index([userId])
}

model ServiceType {
  id              String        @id @default(cuid())
  practiceId      String
  name            String
  description     String?
  durationMinutes Int
  bufferMinutes   Int           @default(0)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  practice        Practice      @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@index([practiceId, active])
}

model TherapistAvailabilityRule {
  id          String    @id @default(cuid())
  practiceId  String
  therapistId String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  timezone    String    @default("America/New_York")
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User      @relation("AvailabilityTherapist", fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([practiceId, therapistId, dayOfWeek])
}

model CalendarBlock {
  id          String    @id @default(cuid())
  practiceId  String
  therapistId String
  startsAt    DateTime
  endsAt      DateTime
  reason      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist   User      @relation("CalendarBlockTherapist", fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([practiceId, therapistId, startsAt])
}

model Appointment {
  id               String            @id @default(cuid())
  practiceId       String
  therapistId      String
  practiceClientId String
  serviceTypeId    String
  createdById      String?
  startsAt         DateTime
  endsAt           DateTime
  status           AppointmentStatus @default(REQUESTED)
  source           AppointmentSource @default(CLIENT_REQUEST)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  practice         Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapist        User              @relation("AppointmentTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  practiceClient   PracticeClient    @relation(fields: [practiceClientId], references: [id], onDelete: Cascade)
  serviceType      ServiceType       @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  createdBy        User?             @relation("AppointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([practiceId, startsAt])
  @@index([therapistId, startsAt])
  @@index([practiceClientId, startsAt])
}
